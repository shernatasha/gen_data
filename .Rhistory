data <- data.frame(
x8 = c(2205, 2096, 1847, 1903, 1457, 1848, 1564, 1821, 2577,
2476, 1984, 1917, 1761, 1709, 1901, 2288, 2072, 2862,
2411, 2289, 2203, 2592, 2053, 1979, 2048, 1786, 2876, 2560),
y = c(10, 11, 11, 13, 10, 11, 10, 11, 4, 2, 7, 10, 9, 9, 6, 5, 5,
5, 6, 4, 3, 3, 4, 10, 6, 8, 2, 0),
x2 = c(1985, 2855, 1737, 2905, 1666, 2927, 2341, 2737, 1414, 1838,
1480, 2191, 2229, 2204, 2140, 1730, 2072, 2929, 2268, 1983,
1792, 1606, 1492, 2835, 2416, 1638, 2649, 1503),
x7 = c(59.7, 55, 65.6, 61.4, 66.1, 61, 66.1, 58, 57, 58.9, 67.5, 57.2,
58.8, 58.6, 59.2, 54.4, 49.6, 54.3, 58.7, 51.7, 61.9, 52.7, 57.8,
59.7, 54.9, 65.3, 43.8, 53.5)
)
X <- cbind(1, data$x2, data$x7, data$x8)
y <- as.matrix(data$y)
ybar = mean(y)
bhat = solve(t(X) %*% X) %*% t(X) %*% y
bhat
yhat = X %*% bhat
yhat
# b) & c)
# H0 : b1 = b2 = ... = bk = 0
# H1 : bj for at least 1 j
SSres = (t(y) %*% y) - (t(bhat) %*% t(X) %*% y)
SSreg = (t(bhat) %*% t(X) %*% y) - (sum(y)^2)/length(data$y)
n = length(data$y)
dfres = n - 3 - 1
dfreg = 3
MSres = SSres/dfres
MSreg = SSreg/dfreg
F0 = MSreg/MSres # 29.4
fcrit <- qf(0.95, df1=dfreg, df2=dfres)
F0 > fcrit #reject H0
1-pf(F0, dfreg, dfres) < 0.05 #3.27e-08
# Tests on individual regression coeffs
# H0: bj = 0 vs H1: bj <> 0
# t0 = bj / sqrt(sigma^2 * Cjj)
# Cjj = diag(solve(t(X) %*% X))
C = solve(t(X) %*% X)
Cjj = diag(C)
t0 = as.vector(bhat)/sqrt(MSres * Cjj)
pval <- 2 * (1 - pt(abs(t0), df = dfres))
# [1] 8.200318e-01 2.644445e-05 3.772483e-02
# [4] 9.369758e-04
# All p values < 0.05, reject H0 and conclude that bj's are not 0
# x2, x7 has a positive relationship with y, while x8 has a negative relationship with y
# when x2 increases by 1 unit, y hat increases by b2 while holding x7 and x8 constant
# similar idea to x7 and x8
# d) R^2 and adjusted_R^2: corrected for # of predictors
# R^2 = SSreg/SSt
# Adjusted R^2 = 1 - (SSres/n-p)/(SSt/n-1)
SSt = SSreg + SSres
# SSt = sum((data$y - ybar)^2)
R_2 = SSreg/SSt
Adjusted_R_2 = 1 - ((SSres/(n - 3))/(SSt/(n - 1)))
# e) Partial F test- determine contribution of x7
# Reduced model: y = b0 + b2x2 + b8x8 + e
X_red <- cbind(1, data$x2, data$x8)
b_red <- solve(t(X_red) %*% X_red) %*% t(X_red) %*% y
yhat_red <- X_red %*% b_red
SSres_red <- sum((data$y - yhat_red)^2)
# Extra SS by x7 = SSres_red - SSres_full
SSres_x7 = SSres_red - SSres
# F0 = SSres_x7/1 / SSres_full/n-4
F0_x7 = SSres_red / SSres/(n - 4)
Fcrit = qf(0.95, df1 = 1, df2 = n-4)
F0_x7 > Fcrit # do not reject H0 as H0: b7 = 0, x7 does not significantly improve the model given x2 and x8
p_val <- 1 - pf(F0_x7, 1, n - 4)
p_val < 0.05 # do not reject H0
model <- lm(y ~ x2 + x7 + x8, data= data)
summary(model)
pval
p_val < 0.05 # do not reject H0
0.05/4
